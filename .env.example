APP_NAME=SDMastery
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5174

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (SQLite)
DB_CONNECTION=sqlite
# DB_DATABASE is auto-resolved to database/database.sqlite by Laravel

# Session (Redis for local docker profile)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue (Redis driver)
QUEUE_CONNECTION=redis

# Cache (Redis driver)
CACHE_STORE=redis
CACHE_PREFIX=

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (log driver for local dev)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@sdmastery.local
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum (SPA auth)
SANCTUM_STATEFUL_DOMAINS=localhost:5174
SESSION_DOMAIN=localhost

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Ollama
OLLAMA_BASE_URL=http://192.168.1.113:11434
OLLAMA_AGENT1_MODEL=llama3:latest
OLLAMA_AGENT2_MODEL=mistral:latest
OLLAMA_SYNTHESIZER=llama3:latest
OLLAMA_EMBEDDER=nomic-embed-text
OLLAMA_CHAT_TIMEOUT=120
OPENAI_CHAT_TIMEOUT=60
GEMINI_CHAT_TIMEOUT=60
GROK_CHAT_TIMEOUT=60

# ChromaDB
CHROMA_BASE_URL=http://localhost:8002
CHROMA_COLLECTION_BOOKS=sdmastery_books
CHROMA_COLLECTION_ANSWERS=sdmastery_model_answers

# Evaluation
EVALUATION_PASS_THRESHOLD=80
EVALUATION_CONTEXT_CHUNKS=5
EVALUATION_ANSWER_CHUNKS=3
EVALUATION_MAX_RETRIES=3
